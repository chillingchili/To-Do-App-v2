<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiApp1.ViewModels"
             x:Class="MauiApp1.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Title="Create Account"
             BackgroundColor="#F5EFE6">

    <ScrollView>
        <VerticalStackLayout Padding="28,0" Spacing="20">

            <!-- Header -->
            <VerticalStackLayout Spacing="6" Margin="0,40,0,0">
                <Label Text="Join Us" FontSize="30" FontAttributes="Bold"
                       TextColor="#3D2B1F" HorizontalOptions="Center"/>
                <Label Text="Create your free account below."
                       FontSize="14" TextColor="#8B6354" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Form Card -->
            <Border BackgroundColor="White" Padding="24" Stroke="#E8D5C4" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="16">

                    <!-- First Name -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="First Name" FontSize="13" FontAttributes="Bold" TextColor="#3D2B1F"/>
                        <Border BackgroundColor="#F5EFE6" Stroke="#D9C4B3" StrokeThickness="1" Padding="14,0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                            <Entry Placeholder="Juan" Keyboard="Default"
                                   Text="{Binding FirstName}" BackgroundColor="Transparent"
                                   TextColor="#3D2B1F" PlaceholderColor="#C5B0A4"
                                   MinimumHeightRequest="48"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Last Name -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Last Name" FontSize="13" FontAttributes="Bold" TextColor="#3D2B1F"/>
                        <Border BackgroundColor="#F5EFE6" Stroke="#D9C4B3" StrokeThickness="1" Padding="14,0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                            <Entry Placeholder="dela Cruz" Keyboard="Default"
                                   Text="{Binding LastName}" BackgroundColor="Transparent"
                                   TextColor="#3D2B1F" PlaceholderColor="#C5B0A4"
                                   MinimumHeightRequest="48"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Email -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Email Address" FontSize="13" FontAttributes="Bold" TextColor="#3D2B1F"/>
                        <Border BackgroundColor="#F5EFE6" Stroke="#D9C4B3" StrokeThickness="1" Padding="14,0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                            <Entry Placeholder="you@example.com" Keyboard="Default"
                                   Text="{Binding Email}" BackgroundColor="Transparent"
                                   TextColor="#3D2B1F" PlaceholderColor="#C5B0A4"
                                   MinimumHeightRequest="48"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Password" FontSize="13" FontAttributes="Bold" TextColor="#3D2B1F"/>
                        <Border BackgroundColor="#F5EFE6" Stroke="#D9C4B3" StrokeThickness="1" Padding="14,0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                            <Entry Placeholder="At least 6 characters" IsPassword="True"
                                   Text="{Binding Password}" BackgroundColor="Transparent"
                                   TextColor="#3D2B1F" PlaceholderColor="#C5B0A4"
                                   MinimumHeightRequest="48"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Confirm Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Confirm Password" FontSize="13" FontAttributes="Bold" TextColor="#3D2B1F"/>
                        <Border BackgroundColor="#F5EFE6" Stroke="#D9C4B3" StrokeThickness="1" Padding="14,0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                            <Entry Placeholder="Repeat your password" IsPassword="True"
                                   Text="{Binding ConfirmPassword}" BackgroundColor="Transparent"
                                   TextColor="#3D2B1F" PlaceholderColor="#C5B0A4"
                                   MinimumHeightRequest="48"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Register Button -->
                    <Button Text="Create Account"
                            Command="{Binding RegisterCommand}"
                            BackgroundColor="#C17F54" TextColor="White"
                            CornerRadius="10" HeightRequest="50"
                            FontAttributes="Bold" FontSize="16"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"/>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="#C17F54" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Back to Login -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,0,0,32">
                <Label Text="Already have an account?" TextColor="#8B6354" FontSize="14"/>
                <Label Text="Sign In" TextColor="#C17F54" FontSize="14" FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
